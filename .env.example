DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="lobby-pro-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Azure OpenAI (optional - app works without it, returning placeholder text)
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_ENDPOINT=""
# AZURE_OPENAI_DEPLOYMENT=""
# AZURE_OPENAI_API_VERSION="2024-02-01"

# Microsoft OAuth - Outlook integration (optional)
# Create an app at https://portal.azure.com > App registrations
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_REDIRECT_URI="http://localhost:3000/api/integrations/microsoft/callback"

# Google OAuth - Drive integration (optional)
# Create credentials at https://console.cloud.google.com > APIs & Services > Credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
